root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
indent_size = 4
indent_style = space
trim_trailing_whitespace = true

[*.md]
indent_size = 2
trim_trailing_whitespace = false

[*.csv]
insert_final_newline = false

[*.yml]
indent_size = 2

[{lib/**/*.c, lib/**/*.h}]
indent_size = 3

# MeCab ソースは brace 展開よりディレクトリ glob の方が .h/.cpp とも確実に 2 スペースになる
[lib/open_jtalk/src/mecab/src/**]
indent_size = 2
